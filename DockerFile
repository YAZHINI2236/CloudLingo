# Use official Java 17 image
FROM eclipse-temurin:17-jdk

# Set working directory
WORKDIR /app

# Copy everything
COPY . .

# Build the app
RUN ./mvnw clean package -DskipTests

# Expose port (Render uses 10000+ but Spring will use env PORT)
EXPOSE 8080

# Run the jar
CMD ["java", "-jar", "target/*.jar"]
